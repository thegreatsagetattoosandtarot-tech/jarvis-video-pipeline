# J.A.R.V.I.S. Cron Jobs Configuration
# Install with: crontab /opt/data/jarvis/config/crontab.jobs
# Or manually add to your crontab with: crontab -e

# Environment
SHELL=/bin/bash
PATH=/opt/data/jarvis/venv/bin:/usr/local/bin:/usr/bin:/bin
JARVIS_ROOT=/opt/data/jarvis
LOGS_DIR=/opt/data/jarvis/logs

# === DAILY JOBS ===

# Daily Report - 06:00
0 6 * * * /opt/data/jarvis/venv/bin/python /opt/data/jarvis/skills/cron-automation/jobs/daily_report.py >> /opt/data/jarvis/logs/daily_report.log 2>&1

# Weather Summary - 06:15
15 6 * * * /opt/data/jarvis/venv/bin/python /opt/data/jarvis/skills/cron-automation/jobs/weather_fetcher.py >> /opt/data/jarvis/logs/weather.log 2>&1

# Stock Report - 09:30 (market days Mon-Fri)
30 9 * * 1-5 /opt/data/jarvis/venv/bin/python /opt/data/jarvis/skills/cron-automation/jobs/stock_reporter.py >> /opt/data/jarvis/logs/stock_report.log 2>&1

# Task Summary - 08:00
0 8 * * * /opt/data/jarvis/venv/bin/python /opt/data/jarvis/skills/cron-automation/jobs/task_summarizer.py >> /opt/data/jarvis/logs/task_summary.log 2>&1

# Financial Report - 18:00
0 18 * * * /opt/data/jarvis/venv/bin/python /opt/data/jarvis/skills/cron-automation/jobs/financial_reporter.py >> /opt/data/jarvis/logs/financial_report.log 2>&1

# Nightly Audit - 02:00
0 2 * * * /opt/data/jarvis/venv/bin/python /opt/data/jarvis/skills/cron-automation/jobs/nightly_audit.py >> /opt/data/jarvis/logs/nightly_audit.log 2>&1

# Dream Process - 03:00
0 3 * * * /opt/data/jarvis/venv/bin/python /opt/data/jarvis/skills/cron-automation/jobs/dream_process.py >> /opt/data/jarvis/logs/dream_process.log 2>&1

# Hostinger Backup - 04:00
0 4 * * * /opt/data/jarvis/scripts/backup_hostinger.sh >> /opt/data/jarvis/logs/hostinger_backup.log 2>&1

# Vector Memory Re-index - 05:00
0 5 * * * /opt/data/jarvis/venv/bin/python /opt/data/jarvis/skills/vector-memory-rag/index_brains.py >> /opt/data/jarvis/logs/vector_reindex.log 2>&1

# === WEEKLY JOBS ===

# Weekly Review - Monday 07:00
0 7 * * 1 /opt/data/jarvis/venv/bin/python /opt/data/jarvis/skills/cron-automation/jobs/weekly_review.py >> /opt/data/jarvis/logs/weekly_review.log 2>&1

# === MONTHLY JOBS ===

# Monthly Review - 1st of month 08:00
0 8 1 * * /opt/data/jarvis/venv/bin/python /opt/data/jarvis/skills/cron-automation/jobs/monthly_review.py >> /opt/data/jarvis/logs/monthly_review.log 2>&1

# === HEALTH CHECKS ===

# System Health Check - every 15 minutes
*/15 * * * * /opt/data/jarvis/venv/bin/python /opt/data/jarvis/skills/cron-automation/jobs/health_check.py >> /opt/data/jarvis/logs/health_check.log 2>&1